OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Optional chat/orchestration overrides. Leave these alone unless you want to test another OpenRouter model.
OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash
OPENROUTER_ORCHESTRATOR_MODEL=google/gemini-2.5-flash

# Optional OpenAI image overrides.
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=high

OPENROUTER_HTTP_REFERER=http://localhost:8080
OPENROUTER_APP_TITLE=Reel Studio
